<?xml version="1.0"?>
<robot name="so101_photo_style_sim">
  <material name="matte_black">
    <color rgba="0.015 0.015 0.015 1"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.08 0.08 0.08 1"/>
  </material>
  <material name="lens">
    <color rgba="0.02 0.03 0.04 1"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025"/>
      <geometry>
        <box size="0.22 0.16 0.05"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="-0.055 0 0.075"/>
      <geometry>
        <box size="0.10 0.11 0.05"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025"/>
      <geometry>
        <box size="0.22 0.16 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.03"/>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <link name="shoulder_column">
    <visual>
      <origin xyz="0 0 0.22"/>
      <geometry>
        <box size="0.07 0.07 0.44"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.455"/>
      <geometry>
        <box size="0.11 0.09 0.055"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.22"/>
      <geometry>
        <box size="0.07 0.07 0.44"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.22"/>
      <mass value="0.6"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.015 0 0.16"/>
      <geometry>
        <box size="0.055 0.045 0.32"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.015 0 0.16"/>
      <geometry>
        <box size="0.025 0.07 0.20"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0.015 0 0.16"/>
      <geometry>
        <box size="0.055 0.045 0.32"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.015 0 0.16"/>
      <mass value="0.35"/>
      <inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.0015" iyz="0" izz="0.0006"/>
    </inertial>
  </link>

  <link name="forearm_link">
    <visual>
      <origin xyz="0.035 0 0.12"/>
      <geometry>
        <box size="0.055 0.045 0.24"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.06 0 0.23"/>
      <geometry>
        <box size="0.13 0.06 0.055"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0.035 0 0.12"/>
      <geometry>
        <box size="0.055 0.045 0.24"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.035 0 0.12"/>
      <mass value="0.25"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <link name="wrist_link">
    <visual>
      <origin xyz="0.10 0 0"/>
      <geometry>
        <box size="0.20 0.075 0.065"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.05 0 0.07"/>
      <geometry>
        <box size="0.08 0.075 0.07"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <visual>
      <origin xyz="0.055 -0.039 0.075" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.027" length="0.012"/>
      </geometry>
      <material name="lens"/>
    </visual>
    <collision>
      <origin xyz="0.10 0 0"/>
      <geometry>
        <box size="0.20 0.075 0.065"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.10 0 0"/>
      <mass value="0.18"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <link name="roll_link">
    <visual>
      <origin xyz="0.045 0 0"/>
      <geometry>
        <box size="0.09 0.06 0.045"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0.045 0 0"/>
      <geometry>
        <box size="0.09 0.06 0.045"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.045 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <link name="gripper_link">
    <visual>
      <origin xyz="0.04 0 0"/>
      <geometry>
        <box size="0.08 0.085 0.03"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.11 0.035 0"/>
      <geometry>
        <box size="0.13 0.018 0.025"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.11 -0.035 0"/>
      <geometry>
        <box size="0.13 0.018 0.025"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <collision>
      <origin xyz="0.04 0 0"/>
      <geometry>
        <box size="0.08 0.085 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.04 0 0"/>
      <mass value="0.06"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <link name="gripper_tip">
    <visual>
      <origin xyz="0.02 0 0"/>
      <geometry>
        <box size="0.04 0.03 0.02"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <collision>
      <origin xyz="0.02 0 0"/>
      <geometry>
        <box size="0.04 0.03 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.02 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="shoulder_pan" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_column"/>
    <origin xyz="0 0 0.08"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>

  <joint name="shoulder_lift" type="revolute">
    <parent link="shoulder_column"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.48"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="10" velocity="2"/>
  </joint>

  <joint name="elbow_flex" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.02 0 0.32"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="10" velocity="2"/>
  </joint>

  <joint name="wrist_flex" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.08 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="5" velocity="2"/>
  </joint>

  <joint name="wrist_roll" type="revolute">
    <parent link="wrist_link"/>
    <child link="roll_link"/>
    <origin xyz="0.20 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="5" velocity="2"/>
  </joint>

  <joint name="gripper" type="revolute">
    <parent link="roll_link"/>
    <child link="gripper_link"/>
    <origin xyz="0.09 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="2" velocity="2"/>
  </joint>

  <joint name="gripper_tip_fixed" type="fixed">
    <parent link="gripper_link"/>
    <child link="gripper_tip"/>
    <origin xyz="0.17 0 0"/>
  </joint>
</robot>
